generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MED
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  REJECTED
  SUSPENDED
}

enum TrainingType {
  ONLINE
  HANDS_ON
}

enum TrainingBrand {
  MINT_LIFT_PDO_THREADS
  MINT_MICROCANNULA
  KLARDIE
  TARGETCOOL
  EZ_TCON
}

enum TrainingLevel {
  MINT_LIFT_GROUP_TRAINING
  SUPPLEMENTAL
  ADVANCED
  PACKAGE_BUNDLE_1
  PACKAGE_BUNDLE_2
}

enum CreditTransactionType {
  EARNED // Credit added — e.g. enrolled in a training
  SPENT  // Credit deducted — e.g. store purchase
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id                        String               @id @default(uuid())
  fullName                  String
  email                     String               @unique
  phoneNumber               String               @unique
  password                  String
  role                      Role                 @default(USER)
  accountStatus             AccountStatus        @default(ACTIVE)
  hasSubmittedVerification  Boolean              @default(false)
  medicalLicenseNumber      String?
  idDocumentFrontPath       String?
  idDocumentBackPath        String?
  verificationNotes         String?
  verifiedAt                DateTime?
  verifiedBy                String?
  creditBalance             Int                  @default(0) // Running credit score balance
  profilePicturePath        String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  otps                      Otp[]
  enrollments               Enrollment[]
  creditTransactions        CreditTransaction[]
  chatMessages              ChatMessage[]
  appointments              Appointment[]
}

model Otp {
  id        String   @id @default(uuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Training {
  id                  String        @id @default(uuid())
  type                TrainingType
  brand               TrainingBrand
  level               TrainingLevel
  learningFormats     Json          // String[] — validated values: "DEMO" | "DIDACTIC" | "DISCUSSION"
  title               String
  speaker             String
  speakerIntro        String
  productsUsed        String?
  areasCovered        String
  description         String
  backgroundImagePath String?
  location            String?       // e.g. "Morristown, NJ"
  scheduledAt         DateTime?     // When the training is scheduled
  price               Int           // USD — auto-populated from level at creation
  creditScore         Int           // In-house currency earned on enrollment — auto-populated from level
  createdBy           String        // admin userId
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  enrollments         Enrollment[]
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, trainingId])
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        CreditTransactionType
  amount      Int                   // Always positive — type determines direction
  description String                // Human-readable e.g. "Enrolled in Advanced PDO Thread Techniques"
  referenceId String?               // Optional — trainingId, orderId, etc.
  createdAt   DateTime              @default(now())
}

model Appointment {
  id              String            @id @default(uuid())
  medUserId       String
  medUser         User              @relation(fields: [medUserId], references: [id], onDelete: Cascade)
  date            String            // "YYYY-MM-DD" e.g. "2026-03-18"
  time            String            // e.g. "10:00 AM"
  notes           String?           // Optional context from MED user
  status          AppointmentStatus @default(PENDING)
  zoomLink        String?           // Filled on approval from ZOOM_MEETING_LINK env var
  rejectionReason String?           // Filled on rejection — also sent as email
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String?
  imageUrl  String?
  createdAt DateTime @default(now())
}
